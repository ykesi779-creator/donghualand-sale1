# DonghuaLand Environment Variables
# Copy this file to .dev.vars for local development
# For production, set these as Cloudflare Pages secrets

# ===== REQUIRED =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# JWT secret for token signing (generate with: openssl rand -hex 32)
JWT_SECRET=your_random_jwt_secret_here_change_this

# ===== OPTIONAL =====
# TMDB API key for auto-filling anime info (get free at themoviedb.org/settings/api)
# Used by /api/tmdb/search (Movies + TV) and /api/tmdb/{tv|movie}/:id
TMDB_API_KEY=your_tmdb_api_key_here

# Jikan / MyAnimeList: NO API key required.
# The admin "Search with Jikan" button uses the public Jikan v4 REST API
# (https://jikan.moe) which is the open mirror of MyAnimeList data.

# IMGBB API key for image uploads (get free at https://api.imgbb.com/)
# Used for uploading anime cover images, banner images, episode thumbnails, and profile pictures
IMGBB_API_KEY=your_imgbb_api_key_here
