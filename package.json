{
  "name": "donghualand",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "wrangler pages dev dist --ip 0.0.0.0 --port 3000",
    "dev:local": "wrangler pages dev dist --d1=donghualand-production --local --ip 0.0.0.0 --port 3000",
    "deploy": "npm run build && wrangler pages deploy dist --project-name donghualand",
    "db:create": "wrangler d1 create donghualand-production",
    "db:migrate:local": "wrangler d1 migrations apply donghualand-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply donghualand-production",
    "db:seed:local": "wrangler d1 execute donghualand-production --local --file=./seed.sql",
    "db:seed:prod": "wrangler d1 execute donghualand-production --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed:local",
    "db:console:local": "wrangler d1 execute donghualand-production --local",
    "db:console:prod": "wrangler d1 execute donghualand-production",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "hono": "^4.12.9"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250705.0",
    "@hono/node-server": "^1.14.0",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
